# ── Exit codes ────────────────────────────────────────────────────────────────
EXIT_OK = 0
EXIT_NO_ENTITIES = 10
EXIT_PDF_READ_ERROR = 20
EXIT_NO_TEXT_PAGES = 21
EXIT_MODEL_ERROR = 30
EXIT_INVALID_JSON = 31
EXIT_NEO4J_ERROR = 40
EXIT_NO_SPACE = 50
EXIT_LOCKED = 60
EXIT_REQUIRES_OCR = 70

NEXTCLOUD_BASE = "/mnt/nextcloud-rol"

