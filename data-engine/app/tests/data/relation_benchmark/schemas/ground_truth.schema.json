{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "relation-benchmark/ground_truth.schema.json",
  "title": "Relation benchmark ground truth",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "corpus_version",
    "description",
    "temporal_status_values",
    "expected_decision_values",
    "relations"
  ],
  "properties": {
    "corpus_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "temporal_status_values": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_decision_values": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "relations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "relation_id",
          "source_id",
          "workspace",
          "segment_id",
          "subject_id",
          "subject_text",
          "subject_type",
          "predicate",
          "object_id",
          "object_text",
          "object_type",
          "evidence_text",
          "evidence_start",
          "evidence_end",
          "negated",
          "temporal_status",
          "epistemic_status",
          "direction",
          "expected_decision",
          "annotator_notes"
        ],
        "properties": {
          "relation_id": {
            "type": "string",
            "pattern": "^rel-\\d+$"
          },
          "source_id": {
            "type": "string",
            "pattern": "^src-\\d+$"
          },
          "workspace": {
            "type": "string",
            "minLength": 1
          },
          "segment_id": {
            "type": "string",
            "minLength": 1
          },
          "subject_id": {
            "type": "string",
            "minLength": 1
          },
          "subject_text": {
            "type": "string",
            "minLength": 1
          },
          "subject_type": {
            "enum": [
              "Character",
              "Location",
              "Faction",
              "Object",
              "Event",
              "Concept"
            ]
          },
          "predicate": {
            "type": "string",
            "pattern": "^[A-Z][A-Z_]*$"
          },
          "object_id": {
            "type": "string",
            "minLength": 1
          },
          "object_text": {
            "type": "string",
            "minLength": 1
          },
          "object_type": {
            "enum": [
              "Character",
              "Location",
              "Faction",
              "Object",
              "Event",
              "Concept"
            ]
          },
          "evidence_text": {
            "type": "string",
            "minLength": 1
          },
          "evidence_start": {
            "type": "integer",
            "minimum": 0
          },
          "evidence_end": {
            "type": "integer",
            "minimum": 0
          },
          "negated": {
            "type": "boolean"
          },
          "temporal_status": {
            "enum": [
              "PAST",
              "PRESENT",
              "FUTURE",
              "ONGOING",
              "ENDED",
              "ATEMPORAL"
            ]
          },
          "epistemic_status": {
            "enum": [
              "ASSERTED",
              "RUMORED",
              "HYPOTHETICAL",
              "INTENDED"
            ]
          },
          "direction": {
            "enum": [
              "SUBJECT_TO_OBJECT",
              "OBJECT_TO_SUBJECT",
              "UNDIRECTED"
            ]
          },
          "expected_decision": {
            "enum": [
              "ACCEPT",
              "REJECT",
              "REVIEW"
            ]
          },
          "annotator_notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
