# viewer.env.example — plantilla VERSIONADA de configuración del visor S9 Knowledge.
#
# La configuración productiva REAL vive en /etc/s9-knowledge/viewer.env (fuera del
# repo, fuera de la release). Esta plantilla NO contiene secretos: los valores
# sensibles (S9K_NEO4J_PASSWORD, S9K_CSRF_SECRET) deben rellenarse en el host o
# apuntarse a ficheros de secretos (…_FILE).
#
# Nombres de variables tomados VERBATIM del código (viewer/app/config.py y
# viewer/app/auth/config.py). No inventar variables.
#
# El despliegue BLOQUEA si faltan las variables marcadas [CRÍTICA].

# --- Servidor del visor ---
S9K_VIEWER_HOST=127.0.0.1            # [CRÍTICA]
S9K_VIEWER_PORT=8088                 # [CRÍTICA]

# --- Grafo / Neo4j ---
S9K_GRAPH_PROVIDER=neo4j             # [CRÍTICA] "mock" | "neo4j"
S9K_DEFAULT_WORKSPACE=leyenda
S9K_GRAPH_LIMIT=300
S9K_NEO4J_URI=bolt://127.0.0.1:7687  # [CRÍTICA]
S9K_NEO4J_USER=neo4j                 # [CRÍTICA]
# Secreto: NO poner aquí. Usar fichero de secreto en el host:
S9K_NEO4J_PASSWORD_FILE=/etc/s9-knowledge/secrets/neo4j_password
#S9K_NEO4J_PASSWORD=

# --- Estado externo (state root) ---
# [CRÍTICA] Rutas absolutas bajo el state root; nunca bajo la release.
S9K_AUTH_DB_PATH=/var/lib/s9-knowledge/auth/auth.db
S9K_JOBS_DB=/var/lib/s9-knowledge/jobs/jobs.db
S9K_BACKUP_DIR=/var/lib/s9-knowledge/backups

# --- Autenticación ---
S9K_AUTH_ENABLED=true                # [CRÍTICA]
S9K_AUTH_MAX_FAILED_ATTEMPTS=5
S9K_AUTH_LOCK_MINUTES=15
S9K_AUTH_EXPOSE_DOCS=false
# Confiar en cabeceras de proxy (X-Forwarded-For). FALSE por defecto: solo
# poner true si TODOS los accesos pasan por un reverse proxy conocido que
# filtra las cabeceras entrantes y hay una lista de proxies confiables, sin
# acceso directo no confiable. Ver docs/50-deploy-state-continuity.md.
S9K_AUTH_TRUST_PROXY_HEADERS=false
# Secreto CSRF [CRÍTICA]: NO se versiona ningún valor. El código NO soporta
# S9K_CSRF_SECRET_FILE, así que debe definirse en el host, en este fichero.
# Genera uno fuerte (>=32 chars, alta entropía):  openssl rand -hex 32
# La validación rechaza vacío, placeholders (change-me, default, secret, ...),
# valores cortos o de baja entropía, y secretos guardados dentro de la release.
#S9K_CSRF_SECRET=

# --- Sesiones ---
S9K_SESSION_COOKIE_NAME=s9k_session
S9K_SESSION_TTL_HOURS=12
S9K_SESSION_IDLE_MINUTES=60
S9K_SESSION_SECURE=true
S9K_SESSION_SAMESITE=lax
S9K_SESSION_HTTPONLY=true

# --- Healthchecks ---
S9K_HEALTH_VIEWER_URL=http://127.0.0.1:8088
S9K_HEALTH_REPORT_PATH=/var/lib/s9-knowledge/health/health.json
S9K_HEALTH_UNITS=s9-knowledge-viewer.service
S9K_HEALTH_DISK_PATH=/var/lib/s9-knowledge

# --- Paginación / límites del visor ---
S9K_VIEWER_DEFAULT_PAGE_SIZE=50
S9K_VIEWER_MAX_PAGE_SIZE=200
S9K_VIEWER_QUERY_TIMEOUT_SECONDS=10
S9K_VIEWER_MAX_SEARCH_LENGTH=200
