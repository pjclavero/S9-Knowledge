S9K_VIEWER_HOST=127.0.0.1
S9K_VIEWER_PORT=8088
S9K_GRAPH_PROVIDER=mock
S9K_DEFAULT_WORKSPACE=leyenda
S9K_GRAPH_LIMIT=300

# Solo para provider neo4j (no probado aún desde local; VM105 queda intacta).
S9K_NEO4J_URI=bolt://192.168.1.205:7687
S9K_NEO4J_USER=neo4j
S9K_NEO4J_PASSWORD=
S9K_NEO4J_PASSWORD_FILE=

# --- Autenticación del visor (Fase viewer-auth-foundation) ---
# Poner en true para activar login/sesiones/roles. false = comportamiento anterior.
S9K_AUTH_ENABLED=false
# Ruta de la base de datos SQLite de autenticación (se crea automáticamente)
S9K_AUTH_DB_PATH=
# Nombre de la cookie de sesión
S9K_SESSION_COOKIE_NAME=s9k_session
# Duración máxima de la sesión en horas
S9K_SESSION_TTL_HOURS=12
# Expiración por inactividad en minutos (0 = sin límite de inactividad)
S9K_SESSION_IDLE_MINUTES=60
# Poner en false solo en desarrollo local sin HTTPS
S9K_SESSION_SECURE=true
S9K_SESSION_SAMESITE=lax
# Número máximo de intentos de login antes de bloquear la cuenta
S9K_AUTH_MAX_FAILED_ATTEMPTS=5
# Minutos que dura el bloqueo por intentos fallidos
S9K_AUTH_LOCK_MINUTES=15
# Exponer /docs, /redoc y /openapi.json. Por defecto NO se registran. Cuando
# es true y auth está activa, solo el rol admin puede verlos (anónimo → 401).
S9K_AUTH_EXPOSE_DOCS=false
# Confiar en X-Forwarded-For / X-Forwarded-Proto (solo si el reverse proxy es de confianza)
S9K_AUTH_TRUST_PROXY_HEADERS=false
# Secreto CSRF — OBLIGATORIO en producción. Con S9K_AUTH_ENABLED=true el arranque
# aborta si está vacío, es el valor por defecto, es corto (<32) o de baja entropía.
# Generarlo así (NO commitear el valor real):
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
S9K_CSRF_SECRET=
